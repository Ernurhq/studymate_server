AI_PROVIDER=openrouter

# OpenRouter (recommended): can use NVIDIA-hosted models via OpenRouter routing.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
APP_URL=http://localhost:8787
APP_NAME=StudyMate AI

# Direct NVIDIA API (optional). Use when AI_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-REPLACE_ME
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
PORT=8787
